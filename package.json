{
  "name": "superobjective-editable-islands-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.2",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "test": "vitest run",
